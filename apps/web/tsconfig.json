{
    "extends": "@paygate/tsconfig/nextjs.json",
    "compilerOptions": {
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@paygate/db": [
                "../../packages/db/src/index.ts"
            ],
            "@paygate/db/schema": [
                "../../packages/db/src/schema/index.ts"
            ],
            "@paygate/queue": [
                "../../packages/queue/src/index.ts"
            ],
            "@paygate/shared": [
                "../../packages/shared/src/index.ts"
            ]
        },


        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}