{
    "name": "@paygate/db",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./schema": {
            "types": "./src/schema/index.ts",
            "import": "./src/schema/index.ts",
            "default": "./src/schema/index.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "generate": "drizzle-kit generate",
        "migrate": "drizzle-kit migrate",
        "push": "drizzle-kit push",
        "studio": "drizzle-kit studio",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.2",
        "postgres": "^3.4.0"
    },
    "devDependencies": {
        "@paygate/tsconfig": "workspace:*",
        "@types/node": "^20.0.0",
        "drizzle-kit": "^0.30.0",
        "typescript": "^5.7.0"
    }
}