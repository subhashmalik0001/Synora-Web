{
    "name": "@paygate/shared",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./validators": {
            "types": "./src/validators/index.ts",
            "import": "./src/validators/index.ts",
            "default": "./src/validators/index.ts"
        },
        "./constants": {
            "types": "./src/constants.ts",
            "import": "./src/constants.ts",
            "default": "./src/constants.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "@paygate/tsconfig": "workspace:*"
