{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "extends": "./base.json",
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "dom",
            "dom.iterable",
            "ES2022"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "jsx": "preserve",
        "plugins": [
            {
                "name": "next"
            }
        ],
        "allowJs": true,
        "incremental": true,
        "noEmit": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src",
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}